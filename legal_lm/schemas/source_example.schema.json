{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SourceExample",
  "type": "object",
  "required": [
    "id",
    "source",
    "task_family",
    "user_prompt",
    "reference_answer",
    "reference_reasoning_short",
    "reference_rubric_points",
    "doctrine"
  ],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "source": {"type": "string", "minLength": 1},
    "task_family": {"type": "string", "minLength": 1},
    "user_prompt": {"type": "string", "minLength": 1},
    "reference_answer": {"type": "string", "minLength": 1},
    "reference_reasoning_short": {"type": "string", "minLength": 1},
    "reference_rubric_points": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "doctrine": {"type": "string", "minLength": 1}
  },
  "additionalProperties": true
}
