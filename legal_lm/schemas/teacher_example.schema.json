{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TeacherExample",
  "type": "object",
  "required": [
    "id",
    "source",
    "task_family",
    "user_prompt",
    "teacher_answer",
    "teacher_reasoning_short",
    "teacher_rubric_points",
    "teacher_confidence",
    "split"
  ],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "source": {"type": "string", "minLength": 1},
    "task_family": {"type": "string", "minLength": 1},
    "user_prompt": {"type": "string", "minLength": 1},
    "teacher_answer": {"type": "string", "minLength": 1},
    "teacher_reasoning_short": {"type": "string", "minLength": 1},
    "teacher_rubric_points": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "teacher_confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "split": {
      "type": "string",
      "enum": ["train", "validation", "test"]
    }
  },
  "additionalProperties": true
}
